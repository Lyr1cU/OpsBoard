# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Database — use Session pooler on Vercel / Windows (IPv4)
# Connect dialog → Session pooler → port 5432
DATABASE_URL=postgresql://postgres.xxx:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres?sslmode=require

# Groq (https://console.groq.com/keys)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# App — set to your Vercel URL in production
NEXT_PUBLIC_APP_URL=http://localhost:3000
